<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                              http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <servlet>
        <servlet-name>OrdinateurServlet</servlet-name>
        <servlet-class>servlet.OrdinateurServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>OrdinateurServlet</servlet-name>
        <url-pattern>/ordi</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>OrdinateurServlet</servlet-name>
        <url-pattern>/ordi/liste/json</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ShowFormOrdiServlet</servlet-name>
        <servlet-class>servlet.ShowFormOrdiServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>ShowFormOrdiServlet</servlet-name>
        <url-pattern>/ShowForm</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>servlet.LoginServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>UtilisateurServlet</servlet-name>
        <servlet-class>servlet.UtilisateurServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>UtilisateurServlet</servlet-name>
        <url-pattern>/utilisateurs</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>servlet.LogoutServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>StatistiqueServlet</servlet-name>
        <servlet-class>servlet.StatistiqueServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>StatistiqueServlet</servlet-name>
        <url-pattern>/statistique</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>HistoriqueEtatServlet</servlet-name>
        <servlet-class>servlet.HistoriqueEtatServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>HistoriqueEtatServlet</servlet-name>
        <url-pattern>/historique</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>OrdiEtatServlet</servlet-name>
        <servlet-class>servlet.OrdiEtatServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>OrdiEtatServlet</servlet-name>
        <url-pattern>/ordiEtat</url-pattern>
    </servlet-mapping>

    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

</web-app>
